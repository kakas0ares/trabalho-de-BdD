arquivo = "alunos.txt"

# função para adicionar um aluno
def adicionar_aluno(nome, idade, serie):
    with open(arquivo, "a", encoding="utf-8") as f:
        f.write(f"{nome},{idade},{serie}\n")
    print("Aluno adicionado com sucesso!")


def listar_alunos():
    try:
        with open(arquivo, "r", encoding="utf-8") as f:
            alunos = f.readlines()
            if not alunos:
                print("Nenhum aluno cadastrado.")
            else:
                print("\nLista de alunos:")
                for aluno in alunos:
                    nome, idade, serie = aluno.strip().split(",")
                    print(f"Nome: {nome} | Idade: {idade} | Série: {serie}")
    except FileNotFoundError:
        print("Arquivo ainda não existe.")


def buscar_aluno(nome_busca):
    try:
        with open(arquivo, "r", encoding="utf-8") as f:
            for aluno in f:
                nome, idade, serie = aluno.strip().split(",")
                if nome.lower() == nome_busca.lower():
                    print(f"Encontrado: {nome}, {idade} anos, Série {serie}")
                    return
            print("Aluno não encontrado.")
    except FileNotFoundError:
        print("Arquivo não existe.")

while True:
    print("\n--- Sistema Escolar ---")
    print("1 - Adicionar aluno")
    print("2 - Listar alunos")
    print("3 - Buscar aluno")
    print("4 - Sair")

    opcao = input("Escolha: ")

    if opcao == "1":
        nome = input("Nome: ")
        idade = input("Idade: ")
        serie = input("Série: ")
        adicionar_aluno(nome, idade, serie)

    elif opcao == "2":
        listar_alunos()

    elif opcao == "3":
        nome = input("Digite o nome do aluno: ")
        buscar_aluno(nome)

    elif opcao == "4":
        print("Encerrando...")
        break

    else:
        print("Opção inválida!")
